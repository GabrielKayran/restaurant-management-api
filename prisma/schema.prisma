datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  // previewFeatures = []
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role
}

enum Role {
  STUDENT
  ADMIN
}
